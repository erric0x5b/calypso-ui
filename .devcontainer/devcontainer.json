{
  "name": "calypso-ui",
  "dockerComposeFile": ["../compose.yaml", "../compose.local.yaml"],
  "service": "backend",
  "workspaceFolder": "/app",
  "shutdownAction": "none",
  "overrideCommand": false,
  "extensions": [
    "ms-python.python",
    "ms-python.vscode-pylance"
  ],
  "postCreateCommand": "python -m pip install -r /app/backend/requirements.txt || true",
  "remoteUser": "ETR"
}
